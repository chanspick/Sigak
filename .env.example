# ============================================
# SIGAK Backend — Environment Variables
# ============================================
# Managed in Railway dashboard, not committed.
# This file is documentation only.

# ── Database ──
DATABASE_URL=postgresql+asyncpg://sigak:sigak@localhost:5432/sigak

# ── LLM ──
ANTHROPIC_API_KEY=sk-ant-xxx
LLM_MODEL=claude-sonnet-4-20250514
USE_MOCK_CLIP=true

# ── Kakao OAuth ──
KAKAO_REST_API_KEY=xxx
KAKAO_CLIENT_SECRET=xxx

# ── Auth (MVP v1.1, JWT) ──
# Generate with: openssl rand -hex 32
# Rotating this invalidates all active sessions (acceptable for MVP).
JWT_SECRET=replace-with-32-byte-random-hex

# ── Payment (MVP v1.1, Toss Payments) ──
# Test keys until PG approval (est. 2026-04-20). Live keys go straight to Railway,
# never commit to any file.
TOSS_SECRET_KEY=test_gsk_xxx

# ── Admin ──
ADMIN_KEY=xxx

# ── Storage ──
SIGAK_DATA_DIR=/data/uploads

# ── Integrations ──
ZAPIER_WEBHOOK_NEW_ORDER=https://hooks.zapier.com/...

# (2026-04-23: Toss PG 심사 통과 후 test-login / email-login 엔드포인트 코드 제거됨.
#   Railway 에 TEST_LOGIN_* 환경변수 남아 있으면 대시보드에서 정리)
