{
  "mcpServers": {
    "context7": {
      "$comment": "Windows uses cmd /c which loads PATH automatically (no shell wrapper needed)",
      "command": "cmd",
      "args": [
        "/c",
        "npx -y @upstash/context7-mcp@latest"
      ]
    },
    "sequential-thinking": {
      "command": "cmd",
      "args": [
        "/c",
        "npx -y @modelcontextprotocol/server-sequential-thinking"
      ]
    }
  },
  "staggeredStartup": {
    "enabled": true,
    "delayMs": 500,
    "connectionTimeout": 15000
  }
}