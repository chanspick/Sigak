# ============================================
# SIGAK Web — Environment Variables (Next.js)
# ============================================
# Managed in Vercel dashboard, not committed.
# This file is documentation only.
#
# NEXT_PUBLIC_* vars are exposed to the browser bundle.
# Non-public vars are server-only (used in Route Handlers, Server Components).

# ── API ──
NEXT_PUBLIC_API_URL=https://your-railway-api-url.up.railway.app
NEXT_PUBLIC_SITE_URL=https://www.sigak.asia

# ── Payment (MVP v1.1, Toss Payments) ──
# Test client key until PG approval. Safe to expose to browser by design.
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_gck_xxx
